{
  "name": "job-ops-console",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "build": "npm run web:build",
    "dev:web": "dotenv -e .env -- npm run -w @job-ops/web dev",
    "web:build": "npm run -w @job-ops/web build",
    "web:build:local": "dotenv -e .env -- npm run web:build",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "test:domain": "npm run -w @job-ops/domain test",
    "db:generate": "npx prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate:dev": "dotenv -e .env -- npx prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:seed": "npm run -w @job-ops/db seed",
    "db:seed:local": "dotenv -e .env -- npm run db:seed",
    "scout:seed": "tsx scripts/scout-seed.ts",
    "scout:seed:local": "dotenv -e .env -- npm run scout:seed",
    "scout:run": "tsx scripts/scout-run.ts",
    "scout:run:local": "dotenv -e .env -- npm run scout:run --",
    "scout:run:gateway": "bash scripts/scout-run-gateway.sh",
    "scout:run:gateway:local": "dotenv -e .env -- npm run scout:run:gateway --",
    "scout:run:gateway:scheduled": "bash scripts/scout-run-gateway.sh --trigger=scheduled",
    "scout:run:gateway:backfill": "bash scripts/scout-run-gateway.sh --trigger=backfill",
    "scout:validate": "tsx scripts/scout-validate.ts",
    "scout:validate:local": "dotenv -e .env -- npm run scout:validate",
    "scout:feedback:validate": "tsx scripts/scout-feedback-validate.ts",
    "scout:feedback:validate:local": "dotenv -e .env -- npm run scout:feedback:validate",
    "scout:learning:validate": "tsx scripts/scout-learning-validate.ts",
    "scout:learning:validate:local": "dotenv -e .env -- npm run scout:learning:validate"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
